# Anthropic API key — required for AI querying and prompt-driven charts.
ANTHROPIC_API_KEY=

# Model used for text-to-SQL / chart specs (defaults to claude-sonnet-5).
LIZARD_AI_MODEL=claude-sonnet-5

# Where Lizard stores its own metadata (SQLite file). Defaults to ./data/lizard.sqlite
LIZARD_METADATA_PATH=

# Optional single admin password. If set, the UI requires it to log in.
LIZARD_ADMIN_PASSWORD=

# ---------- logging ----------

# fatal | error | warn | info | debug | trace. Defaults to info.
LIZARD_LOG_LEVEL=

# Log every SQL statement Lizard runs against a target database. These are
# emitted at debug level, so LIZARD_LOG_LEVEL must be debug (or trace) too.
LIZARD_LOG_QUERIES=

# Include bound parameter values in those logs. Off by default: parameters are
# row values, i.e. your users' data. Enable deliberately, in development.
LIZARD_LOG_QUERY_PARAMS=

# Warn on any query slower than this many milliseconds (defaults to 500). Always
# active, independent of LIZARD_LOG_QUERIES — a slow query is usually a
# non-sargable predicate: a cast or function wrapped around an indexed column.
LIZARD_SLOW_QUERY_MS=

# Human-readable log output instead of JSON lines. Defaults to on outside production.
LIZARD_LOG_PRETTY=
